server {
    listen ${NGINX_PORT};
    server_name localhost;
    root /usr/share/nginx/html;
    index index.html;

    # Dynamic DNS resolution: re-resolve backend hostname on each request
    # instead of caching at startup. Prevents proxy failures when backend
    # redeploys and gets a new internal IP while frontend is already running.
    # DNS_RESOLVER is auto-detected from /etc/resolv.conf by docker-entrypoint.sh
    resolver ${DNS_RESOLVER} valid=10s ipv6=off;
    resolver_timeout 5s;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        set $backend "${BACKEND_URL}";
        proxy_pass $backend$request_uri;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 600s;
        client_max_body_size 100m;
    }
}
