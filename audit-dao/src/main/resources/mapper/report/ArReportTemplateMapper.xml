<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.energy.audit.dao.mapper.report.ArReportTemplateMapper">

    <!-- Full result map including BLOB — used for single-row queries -->
    <resultMap id="BaseResultMap" type="com.energy.audit.model.entity.report.ArReportTemplate">
        <id column="id" property="id"/>
        <result column="template_name" property="templateName"/>
        <result column="template_file_path" property="templateFilePath"/>
        <result column="template_file_data" property="templateFileData"/>
        <result column="original_file_name" property="originalFileName"/>
        <result column="version" property="version"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- Light result map excluding BLOB — used for list queries -->
    <resultMap id="LightResultMap" type="com.energy.audit.model.entity.report.ArReportTemplate">
        <id column="id" property="id"/>
        <result column="template_name" property="templateName"/>
        <result column="template_file_path" property="templateFilePath"/>
        <result column="original_file_name" property="originalFileName"/>
        <result column="version" property="version"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ar_report_template (template_name, template_file_path, template_file_data,
                                        original_file_name, version, status,
                                        create_by, update_by)
        VALUES (#{templateName}, #{templateFilePath}, #{templateFileData},
                #{originalFileName}, #{version}, #{status},
                #{createBy}, #{updateBy})
    </insert>

    <update id="update">
        UPDATE ar_report_template
        <set>
            <if test="templateName != null">template_name = #{templateName},</if>
            <if test="templateFilePath != null">template_file_path = #{templateFilePath},</if>
            <if test="templateFileData != null">template_file_data = #{templateFileData},</if>
            <if test="originalFileName != null">original_file_name = #{originalFileName},</if>
            <if test="version != null">version = #{version},</if>
            <if test="status != null">status = #{status},</if>
            update_by = #{updateBy},
            update_time = CURRENT_TIMESTAMP,
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM ar_report_template
        WHERE id = #{id} AND deleted = 0
    </select>

    <!-- List queries use LightResultMap to avoid loading BLOB -->
    <select id="selectAll" resultMap="LightResultMap">
        SELECT id, template_name, template_file_path, original_file_name, version, status,
               create_by, create_time, update_by, update_time, deleted
        FROM ar_report_template
        WHERE deleted = 0
        ORDER BY create_time DESC
    </select>

    <select id="selectActive" resultMap="BaseResultMap">
        SELECT * FROM ar_report_template
        WHERE status = 1 AND deleted = 0
        ORDER BY version DESC
        LIMIT 1
    </select>

    <update id="softDelete">
        UPDATE ar_report_template
        SET deleted = 1, update_by = #{updateBy}, update_time = CURRENT_TIMESTAMP
        WHERE id = #{id} AND deleted = 0
    </update>

</mapper>
