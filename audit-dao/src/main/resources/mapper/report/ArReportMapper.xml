<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.energy.audit.dao.mapper.report.ArReportMapper">

    <resultMap id="BaseResultMap" type="com.energy.audit.model.entity.report.ArReport">
        <id column="id" property="id"/>
        <result column="enterprise_id" property="enterpriseId"/>
        <result column="audit_year" property="auditYear"/>
        <result column="report_name" property="reportName"/>
        <result column="report_type" property="reportType"/>
        <result column="status" property="status"/>
        <result column="generated_file_path" property="generatedFilePath"/>
        <result column="uploaded_file_path" property="uploadedFilePath"/>
        <result column="onlyoffice_doc_key" property="onlyofficeDocKey"/>
        <result column="generate_time" property="generateTime"/>
        <result column="submit_time" property="submitTime"/>
        <result column="report_html" property="reportHtml"/>
        <result column="template_id" property="templateId"/>
        <result column="submission_id" property="submissionId"/>
        <result column="flow_chart_path" property="flowChartPath"/>
        <result column="review_comment" property="reviewComment"/>
        <result column="reviewer_id" property="reviewerId"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <result column="enterprise_name" property="enterpriseName"/>
    </resultMap>

    <!-- Light result map without report_html (which can be very large) -->
    <resultMap id="LightResultMap" type="com.energy.audit.model.entity.report.ArReport">
        <id column="id" property="id"/>
        <result column="enterprise_id" property="enterpriseId"/>
        <result column="audit_year" property="auditYear"/>
        <result column="report_name" property="reportName"/>
        <result column="report_type" property="reportType"/>
        <result column="status" property="status"/>
        <result column="generated_file_path" property="generatedFilePath"/>
        <result column="uploaded_file_path" property="uploadedFilePath"/>
        <result column="generate_time" property="generateTime"/>
        <result column="submit_time" property="submitTime"/>
        <result column="template_id" property="templateId"/>
        <result column="submission_id" property="submissionId"/>
        <result column="flow_chart_path" property="flowChartPath"/>
        <result column="review_comment" property="reviewComment"/>
        <result column="reviewer_id" property="reviewerId"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
        <result column="enterprise_name" property="enterpriseName"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ar_report (enterprise_id, audit_year, report_name, report_type,
                               status, generated_file_path, generate_time,
                               report_html, template_id, submission_id, flow_chart_path,
                               create_by, update_by)
        VALUES (#{enterpriseId}, #{auditYear}, #{reportName}, #{reportType},
                #{status}, #{generatedFilePath}, #{generateTime},
                #{reportHtml}, #{templateId}, #{submissionId}, #{flowChartPath},
                #{createBy}, #{updateBy})
    </insert>

    <update id="update">
        UPDATE ar_report
        <set>
            <if test="reportName != null">report_name = #{reportName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="generatedFilePath != null">generated_file_path = #{generatedFilePath},</if>
            <if test="uploadedFilePath != null">uploaded_file_path = #{uploadedFilePath},</if>
            <if test="generateTime != null">generate_time = #{generateTime},</if>
            <if test="submitTime != null">submit_time = #{submitTime},</if>
            <if test="reportHtml != null">report_html = #{reportHtml},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="submissionId != null">submission_id = #{submissionId},</if>
            <if test="flowChartPath != null">flow_chart_path = #{flowChartPath},</if>
            <if test="reviewComment != null">review_comment = #{reviewComment},</if>
            <if test="reviewerId != null">reviewer_id = #{reviewerId},</if>
            update_by = #{updateBy},
            update_time = CURRENT_TIMESTAMP,
        </set>
        WHERE id = #{id} AND deleted = 0
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT r.*, e.enterprise_name
        FROM ar_report r
        LEFT JOIN ent_enterprise e ON e.id = r.enterprise_id
        WHERE r.id = #{id} AND r.deleted = 0
    </select>

    <select id="selectByEnterprise" resultMap="BaseResultMap">
        SELECT r.*, e.enterprise_name
        FROM ar_report r
        LEFT JOIN ent_enterprise e ON e.id = r.enterprise_id
        WHERE r.enterprise_id = #{enterpriseId} AND r.deleted = 0
        <if test="auditYear != null">
            AND r.audit_year = #{auditYear}
        </if>
        ORDER BY r.create_time DESC
    </select>

    <select id="selectByEnterpriseAndYear" resultMap="BaseResultMap">
        SELECT * FROM ar_report
        WHERE enterprise_id = #{enterpriseId}
          AND audit_year = #{auditYear}
          AND report_type = #{reportType}
          AND deleted = 0
        ORDER BY update_time DESC
        LIMIT 1
    </select>

</mapper>
