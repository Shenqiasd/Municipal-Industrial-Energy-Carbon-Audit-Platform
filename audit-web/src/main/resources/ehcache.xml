<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.ehcache.org/v3"
        xsi:schemaLocation="http://www.ehcache.org/v3
        http://www.ehcache.org/schema/ehcache-core-3.10.xsd">

    <!-- Token blacklist for logout -->
    <cache alias="tokenBlacklist">
        <expiry>
            <ttl unit="hours">24</ttl>
        </expiry>
        <heap unit="entries">10000</heap>
    </cache>

    <!-- Dictionary data cache -->
    <cache alias="dictCache">
        <expiry>
            <ttl unit="hours">1</ttl>
        </expiry>
        <heap unit="entries">500</heap>
    </cache>

    <!-- Energy settings cache -->
    <cache alias="energyCache">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <heap unit="entries">200</heap>
    </cache>

    <!-- Template metadata cache -->
    <cache alias="templateCache">
        <expiry>
            <ttl unit="hours">1</ttl>
        </expiry>
        <heap unit="entries">100</heap>
    </cache>

</config>
